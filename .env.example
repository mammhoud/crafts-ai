# =============================================================================
# django-seed Email Automation – Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Reporting Email Addresses
# -----------------------------------------------------------------------------
# The "From" address used when sending automated reports and alerts.
REPORT_EMAIL_FROM=reports@example.com

# The "To" address that receives weekly reports and critical alerts.
REPORT_EMAIL_TO=admin@example.com

# -----------------------------------------------------------------------------
# SMTP / Email Server Configuration
# -----------------------------------------------------------------------------
# Hostname of your SMTP server (e.g. smtp.gmail.com, smtp.sendgrid.net)
EMAIL_HOST=smtp.gmail.com

# SMTP port – 587 for STARTTLS, 465 for SSL, 25 for plain (not recommended)
EMAIL_PORT=587

# SMTP authentication credentials
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-smtp-password

# Set to True to use STARTTLS (recommended), False to disable
EMAIL_USE_TLS=True

# -----------------------------------------------------------------------------
# Django Q Background Task Queue (Redis broker)
# -----------------------------------------------------------------------------
# Hostname of the Redis instance used by Django Q
DJANGO_Q_REDIS_HOST=localhost

# Redis port (default: 6379)
DJANGO_Q_REDIS_PORT=6379

# Number of Django Q worker processes to spawn
DJANGO_Q_WORKERS=4

# -----------------------------------------------------------------------------
# Email Automation Data
# -----------------------------------------------------------------------------
# Path to the CSV file containing email recipients and their roles.
# Relative paths are resolved from the Django project root (BASE_DIR).
EMAILS_CSV_PATH=emails.csv

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
# Base URL of the site – used to build invitation links in email templates.
SITE_URL=http://localhost:8000
